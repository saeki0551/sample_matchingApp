<%= stylesheet_link_tag "users_index", media: "all" %>
<% @users.each do |user| %>
  <div class="user">
    <%= link_to user_path(user) do %>
      <%= image_tag user.user_information.image %>
    <% end %>
    <div class="user-like">
      <% if current_user.liked_user?(liked_user_id: user.id) %>
        <%= render partial: 'likes/destroy', locals: { like: current_user.likes.find_by(liked_user_id: user.id) } %>
      <% else %>
        <%= render partial: 'likes/create', locals: { user_id: user.id } %>
      <% end %>
    </div>
    <div class="user-data">
      <ul>
        <li><%= user.user_information.age %>歳</li>
        <li><%= user.user_information.prefecture.name %></li>
      </ul>
    </div>
  </div>
<% end %>