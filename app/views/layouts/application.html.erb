<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sample Matching App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <header>
    <div class="navigation">
      <ul>
        <li><%= image_tag "navigationIcon.png", size: "50x50" %><br></li>
        <% if user_signed_in? %>
          <li><%= link_to "マッチングした相手", root_path,  class:"navigation-link" %></li>
          <li><%= link_to "メッセージ", root_path,  class:"navigation-link" %></li>
          <li><%= link_to "検索", root_path,  class:"navigation-link" %></li>
          <li><%= link_to "マイページ", root_path,  class:"navigation-link" %></li>
          <li><%= link_to "ログアウト", destroy_user_session_path, method: :delete, class:"navigationLink sessionLink" %></li>
        <% else %>
          <li><%= link_to "ホーム", root_path, class:"navigation-link" %></li>
          <li><%= link_to "コラム", root_path, class:"navigation-link" %></li>
          <li><%= link_to "料金", root_path,  class:"navigation-link" %></li>
          <li><%= link_to "ログイン", new_user_session_path, class:"navigation-link session-link" %></li>
          <li><%= link_to "アカウント作成", new_user_registration_path, class:"navigation-link session-link new-user-link" %></li>
        <% end %>
      </ul>
    </div>
  </header>
  
  <body>
    <main>
      <% flash.each do |name, msg| %>
        <%= content_tag :div, msg, class: name %>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
