<h2>マッチング相手一覧ページ</h2>
<% @likes.each do |like| %>
  <% if current_user.liked_user?(liked_user_id: like.user_id) %>
    <%= image_tag like.user.user_information.image, size: "50x50" %></br>
    <ul>
      <li>メールアドレス：<%= like.user.email %></li>
      <li>名前：<%= link_to "#{ like.user.user_information.name }", user_path(like.user) %></li>
      <li>年齢：<%= like.user.user_information.age %></li>
      <li>生年月日：<%= like.user.user_information.birth_date %></li>
      <li>都道府県：<%= like.user.user_information.prefecture.name %></li>
      <li>趣味：<%= like.user.user_information.hobby.name %></li>
    </ul>
  <% end %>
<% end %>
